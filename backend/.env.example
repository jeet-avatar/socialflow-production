# SocialFlow Backend — Environment Variables
# Copy to .env and fill in values

# Runtime environment
ENVIRONMENT=development
# development | production

# CORS — comma-separated list of allowed origins
# In production this MUST be set; wildcard '*' will raise RuntimeError
ALLOWED_ORIGINS=https://socialflow.network,https://app.socialflow.network

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=socialflow

# MongoDB Atlas (used by Config class — required if using Atlas connection)
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_CLUSTER=

# AWS (for Secrets Manager + S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_SECRET_NAME=socialflow/production

# S3 (video storage)
S3_BUCKET_NAME=socialflow-videos

# Auth
JWT_SECRET_KEY=

# AI APIs
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
FAL_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Redis
REDIS_URL=redis://localhost:6379

# Remotion
REMOTION_SERVICE_URL=http://localhost:3001

# Clerk (backend JWT verification)
CLERK_FRONTEND_API=

# Social platform token verification (optional — for new_integration_verify.py)
FB_IG_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN=

# Dev-only — NEVER enable in production
DEV_BYPASS_AUTH=false
