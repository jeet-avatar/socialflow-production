# ========================================
# SocialFlow Backend Environment Variables
# ========================================

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB_NAME=socialflow

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# AWS S3 & CloudFront Configuration
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=suiteflow-demo
CLOUDFRONT_DOMAIN=d2nbx2qjod9qta.cloudfront.net

# Social Media Integrations (Optional - can be configured via UI)
# Facebook
FACEBOOK_PAGE_ID=your_page_id
FACEBOOK_ACCESS_TOKEN=your_page_access_token

# LinkedIn
LINKEDIN_ACCESS_TOKEN=your_linkedin_token
LINKEDIN_PERSON_URN=urn:li:person:XXXXXXXX

# Instagram
INSTAGRAM_ACCESS_TOKEN=your_instagram_token
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic / Claude Configuration (for lead profile cleaning)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# fal.ai Configuration (for AI video backgrounds via Kling — optional, falls back to DALL-E)
FAL_API_KEY=fal-your-api-key-here

# ElevenLabs Configuration (for voice generation)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Integration Encryption Key (for storing user credentials)
INTEGRATION_ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Email Configuration (for email campaigns)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# WhatsApp Configuration (optional)
WHATSAPP_API_KEY=your_whatsapp_api_key

# Clerk Authentication
# Dev:  holy-lemur-67.clerk.accounts.dev  (default, works on localhost)
# Prod: your-app.clerk.accounts.com       (from Clerk dashboard → Production instance → API Keys)
CLERK_FRONTEND_API=holy-lemur-67.clerk.accounts.dev

# Application Settings
DEBUG=False
ENVIRONMENT=production
PORT=8000
HOST=0.0.0.0

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com
