# SocialFlow Frontend — Environment Variables
# Copy to .env.local and fill in values

# API base URL (no trailing slash)
VITE_API_BASE_URL=https://socialflow.network

# CDN / CloudFront URL (no trailing slash)
VITE_CDN_URL=https://d2nbx2qjod9qta.cloudfront.net

# Stripe checkout link for upgrade flow
VITE_STRIPE_CHECKOUT_URL=

# Clerk publishable key
VITE_CLERK_PUBLISHABLE_KEY=

# Dev-only — NEVER enable in production (set to 'true' to bypass Clerk auth locally)
VITE_DEV_BYPASS_AUTH=false
